{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "required": ["strategy", "rules"],
  "additionalProperties": true,
  "properties": {
    "strategy": {
      "type": "string",
      "enum": [
        "almost_one_allow_no_deny",
        "deny-unless-permit",
        "permit-unless-deny",
        "first-applicable",
        "only-one-applicable"
      ]
    },
    "rules": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "priority", "effect"],
        "additionalProperties": true,
        "properties": {
          "name": {
            "type": "string",
            "minLength": 1
          },
          "priority": {
            "type": "number"
          },
          "effect": {
            "type": "string",
            "enum": ["allow", "deny"]
          },
          "operation": {
            "type": ["string", "null"]
          },
          "startDate": {
            "type": "string"
          },
          "endDate": {
            "type": "string"
          },
          "conditions": {
            "type": "array",
            "items": {
              "type": "array",
              "minItems": 3,
              "maxItems": 3,
              "items": [
                {
                  "type": "string",
                  "enum": ["=", "diff", "<", ">", "<=", ">=", "in", "notin", "date>"]
                },
                {
                  "oneOf": [
                    {"type": ["string", "number"]},
                    {
                      "type": "array",
                      "minItems": 3,
                      "maxItems": 3,
                      "items": [
                        {"type": "string", "minLength": 1},
                        {"type": "string", "enum": ["$s", "$r"]},
                        {"type": "string", "minLength": 1}
                      ]
                    }
                  ]
                },
                {
                  "oneOf": [
                    {"type": ["string", "number"]},
                    {
                      "type": "array",
                      "minItems": 3,
                      "maxItems": 3,
                      "items": [
                        {"type": "string", "minLength": 1},
                        {"type": "string", "enum": ["$s", "$r"]},
                        {"type": "string", "minLength": 1}
                      ]
                    }
                  ]
                }
              ]
            }
          }
        }
      }
    }
  }
}
